{
  "name": "vue-modal-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "type-check": "pnpm -r run type-check",
    "lint": "pnpm -r run lint",
